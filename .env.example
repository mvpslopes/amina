PORT=3000
JWT_SECRET=troque-por-uma-string-longa-e-aleatoria

# --- SQLite (desenvolvimento local, padrão se MYSQL_HOST não estiver definido) ---
DATABASE_PATH=./data/amina.db

# --- MySQL (produção / Hostinger) — preencha todos para usar MySQL em vez de SQLite ---
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=u179630068_amina_user
# MYSQL_DATABASE=u179630068_amina_bd
# MYSQL_PASSWORD=sua_senha_aqui

# Opcional: hash bcrypt alternativo para o usuário root (padrão já vem no seed)
# ROOT_PASSWORD_HASH=

# --- GA4 Data API (dashboard nativo de analytics no painel admin) ---
# ID numérico da propriedade GA4 (Admin > Configuração da propriedade)
# Exemplo: 14214509876
# GA4_PROPERTY_ID=
#
# Conta de serviço com acesso "Leitor/Analista" na propriedade GA4
# GA4_CLIENT_EMAIL=analytics-reader@seu-projeto.iam.gserviceaccount.com
# GA4_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
